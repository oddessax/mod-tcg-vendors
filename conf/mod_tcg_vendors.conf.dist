
###############################################################################
#  TCGVendors.BossDrop.DropRate
#
#    The percentage chance for stationery to drop from configured bosses.
#    Only applies when BossDrop is enabled and MailParticipants is 0 or 2.
#
#    Valid range: 1-100
#    Default: 100
#
TCGVendors.BossDrop.DropRate = 100
