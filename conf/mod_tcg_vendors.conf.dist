###############################################################################
#
#  mod-tcg-vendors.conf
#  Configuration for the TCG / Blizzcon Promotional Vendor Module
#
#  Copy this file to your AzerothCore server's module configuration directory
#  as "mod_tcg_vendors.conf" (remove the .dist extension) alongside
#  your other modules .conf files, then edit as desired.
#
###############################################################################

[worldserver]

###############################################################################
#  TCGVendors.Mode
#
#    Controls the overall behaviour of Landro Longshot, Ransin Donner,
#    and Zas'Tysh.
#
#    0 - DISABLED
#        The NPCs revert to their default database gossip behaviour.
#        No item redemption is offered.  Use this to temporarily suspend
#        the system without uninstalling the module or reverting any SQL.
#
#    1 - FREE
#        No redemption codes are required.  Any player can visit an NPC
#        and select items directly from the gossip menu.
#
#        Unique items (mounts, permanent companions, cosmetics) may only
#        be redeemed once per character and are tracked in
#        character_tcg_redeemed.
#
#        Consumable items (charged toys, stackable novelties, and the
#        Scourgewar mini-mounts) are unlimited and may be taken as many
#        times as the player wishes.  See the isConsumable notes in
#        mod_tcg_vendors.cpp for the full classification.
#
#        The GM-only browse restriction is lifted in this mode; all
#        players see the full expansion sub-menu since there is no code
#        to gate on.
#
#    2 - BLIZZ-LIKE  (default)
#        Players must enter a valid pre-generated redemption code at the
#        NPC gossip dialog.  Each code is single-use and is tracked at
#        account level in the account_tcg_codes table.  Item delivery is
#        additionally gated per-character for unique items.
#
#        Use tools/generate_codes.py to generate codes and insert them
#        into the account_tcg_codes table in your characters database.
#
#        The GM free-browse menu remains accessible to GameMaster rank
#        and above for testing and manual item delivery.
#
#    3 - ITEM-SPECIFIC CODE  (original retail experience)
#        Players browse the expansion sub-menus and select a specific item.
#        Each item then prompts for a code.  The code is validated against
#        the account_tcg_codes table AND must match the reward_group of
#        the item the player selected.  A valid code for a different item
#        produces a mismatch error rather than redeeming the wrong reward.
#        Unique items are still one-time per character.  Consumable items
#        allow additional redemptions with additional valid codes.
#
#    Default: 2
#
TCGVendors.Mode = 2

###############################################################################
#  TCGVendors.LandroBoxesMultiRedeem
#
#    Controls whether Landro's Gift Box (54218) and Landro's Pet Box
#    (50301) can be redeemed more than once per character.
#
#    These two items contain a random assortment of other TCG rewards
#    each time they are opened, so some server operators may wish to
#    allow players to collect multiple boxes.
#
#    0 - One-time per character  (default)
#        Both boxes are treated as unique items and recorded in
#        character_tcg_redeemed.  A character may only receive each
#        box once, regardless of how many valid codes they present.
#
#    1 - Unlimited
#        Both boxes are treated as consumables.  A character may
#        receive them any number of times.
#        In Mode 2 (Blizz-like) each code is still single-use; this
#        setting only removes the per-character uniqueness gate,
#        allowing additional boxes to be obtained via additional codes.
#        In Mode 1 (Free) players may take boxes from the menu freely
#        with no limit.
#
#    Default: 0
#
TCGVendors.LandroBoxesMultiRedeem = 0

###############################################################################
