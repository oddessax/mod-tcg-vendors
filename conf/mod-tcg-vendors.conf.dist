###############################################################################
#
#  mod-tcg-vendors.conf
#  Configuration for the TCG / Promotional Vendor Module
#
#  Copy this file to your AzerothCore server's module configuration directory
#  as "mod-tcg-vendors.conf" (remove the .dist extension) alongside your
#  other module .conf files, then edit as desired.
#
#  NPCs covered by this module:
#    Landro Longshot      (NPC 17249) — Booty Bay, TCG card set rewards
#    Ransin Donner        (NPC 2943)  — Ironforge, Blizzcon promotional items
#    Zas'Tysh             (NPC 7951)  — Orgrimmar, Blizzcon promotional items
#    Garel Redrock        (NPC 16070) — Ironforge, murloc companions & promo items
#    Tharl Stonebleeder   (NPC 16076) — Orgrimmar, murloc companions & promo items
#
###############################################################################

[worldserver]

###############################################################################
#  TCGVendors.Mode
#
#    Controls the overall redemption behaviour of all five vendor NPCs.
#
#    0 - DISABLED
#        The NPCs revert to their default database gossip behaviour.
#        No item redemption is offered.  Use this to temporarily suspend
#        the system without uninstalling the module or reverting any SQL.
#
#    1 - FREE
#        No redemption codes required.  Any player can visit an NPC and
#        select items directly from the gossip menu.
#
#        Unique items (mounts, permanent companions, cosmetics) may only
#        be redeemed once per character, tracked in character_tcg_redeemed.
#
#        Consumable items (charged toys, stackable novelties, Scourgewar
#        mini-mounts, War Fuel) are unlimited and may be taken any number
#        of times.  See the isConsumable notes in mod_tcg_vendors.cpp for
#        the full classification.
#
#        War Fuel (Red/Blue) is always freely available regardless of mode,
#        provided the character has already learned the Warbot companion.
#
#    2 - BLIZZ-LIKE  (default)
#        Players must enter a valid pre-generated XXXX-XXXX-XXXX-XXXX code
#        at the NPC root dialog.  Each code is single-use, tracked at
#        account level in account_tcg_codes.  Item delivery is additionally
#        gated per-character for unique items.
#
#        Landro Longshot and the promo vendors (Garel/Tharl) present a
#        single root code-entry dialog — the reward is determined by the
#        code itself, not by any prior browsing step.
#
#        Blizzcon vendors (Ransin/Zas'Tysh) list items directly with a
#        per-item code dialog in this mode.
#
#        Use tools/generate_codes.py to generate codes and insert them
#        into account_tcg_codes in your characters database.
#
#        The GM free-browse menu remains available to Game Masters in all
#        modes for manual item delivery and testing.
#
#    3 - ITEM-SPECIFIC CODE  (closest to original retail experience)
#        Players browse the expansion sub-menus and select a specific item.
#        Each item then prompts for a code.  The code is validated against
#        account_tcg_codes AND must match the reward_group of the item
#        selected.  A valid code for a different item produces a mismatch
#        error rather than redeeming the wrong reward.
#
#    Default: 2
#
TCGVendors.Mode = 2

###############################################################################
#  TCGVendors.LandroBoxesMultiRedeem
#
#    Controls whether Landro's Gift Box (item 54218) and Landro's Pet Box
#    (item 50301) can be redeemed more than once per character.
#
#    These boxes contain a random assortment of TCG rewards each time they
#    are opened, so some server operators may wish to allow multiple claims.
#
#    0 - One-time per character  (default)
#        Both boxes are treated as unique items and recorded in
#        character_tcg_redeemed.  A character may only receive each box
#        once, regardless of how many valid codes are presented.
#
#    1 - Unlimited
#        Both boxes are treated as consumables.  A character may receive
#        them any number of times.  In Mode 2 each code is still single-use;
#        this only removes the per-character uniqueness gate, allowing
#        additional boxes via additional codes.  In Mode 1 players may
#        take boxes from the menu freely with no limit.
#
#    Default: 0
#
TCGVendors.LandroBoxesMultiRedeem = 0

###############################################################################
#
#  B O S S   D R O P   S E T T I N G S
#
#  The boss drop system automatically generates a unique TCG promotional
#  code on each configured boss kill, writes it to account_tcg_codes as
#  unredeemed, and makes it available to players through one or both of the
#  two delivery methods described below.
#
#  On server startup, the module ensures each configured boss entry has a
#  creature_loot_template row guaranteeing a 100% drop of Simple Stationery
#  (item 9311).  If any rows are missing they are inserted automatically and
#  the creature loot tables are reloaded in-process — no manual .reload or
#  server restart is required after adding a new boss to CreatureIds.
#
#  The stationery item contains the generated code along with flavor text
#  identifying the boss defeated, the item that can be redeemed, and the
#  correct vendor NPC to visit.  Players read the code by right-clicking
#  the item in their inventory and selecting "Open".
#
###############################################################################

###############################################################################
#  TCGVendors.BossDrop.Enabled
#
#    Master switch for the entire boss drop system.  When disabled, no
#    codes are generated, no loot rows are modified, and no mail is sent.
#
#    0 - Disabled  (default)
#    1 - Enabled
#
#    Default: 0
#
TCGVendors.BossDrop.Enabled = 0

###############################################################################
#  TCGVendors.BossDrop.CreatureIds
#
#    Comma-separated list of creature_template entry IDs for the bosses
#    that should trigger a code drop on kill.
#
#    On startup, each entry listed here will automatically receive a
#    creature_loot_template row for item 9311 at 100% drop chance if one
#    does not already exist.  The loot tables are then reloaded in-process.
#
#    Removing an entry from this list does NOT delete existing loot template
#    rows — remove those manually from creature_loot_template if desired.
#
#    The following is a list of all Raid boss ID's, followed by a string of all the ID's for use in the config
#
#    10184	Onyxia (Level 80)
#    11502	Ragnaros
#    11583	Nefarian
#    14834	Hakkar
#    15339	Ossirian the Unscarred
#    15690	Prince Malchezaar
#    15727	C'Thun
#    15990	Kel'Thuzad (Level 80)
#    17257	Magtheridon
#    17968	Archimonde
#    19044	Gruul the Dragonkiller
#    19622	Kael'thas Sunstrider
#    21212	Lady Vashj
#    22917	Illidan Stormrage
#    23863	Zul'jin
#    24664	Kael'thas Sunstrider
#    25315	Kil'jaeden
#    28860	Sartharion
#    29120	Anub'arak
#    33288	Yogg-Saron
#    34564	Anub'arak
#    36597	The Lich King
#    
#    -- Individual Progression module variants
#    301000	Onyxia (Level 60)
#    351019	Kel'Thuzad (Level 60)
#    
#    -- Config string:
#    10184, 11502, 11583, 14834, 15339, 15690, 15727, 15990, 17257, 17968, 19044, 19622, 21212, 22917, 23863, 24664, 25315, 28860, 29120, 33288, 34564, 36597, 301000, 351019
#
#    Example: TCGVendors.BossDrop.CreatureIds = 11502,15990,36597
#
#    Default: (empty — no bosses configured)
#
TCGVendors.BossDrop.CreatureIds =

###############################################################################
#  TCGVendors.BossDrop.ItemIds
#
#    Comma-separated list of item entry IDs from the TCG/promotional catalogs.
#    Each boss kill randomly selects one item from this pool, and the
#    generated stationery code will be redeemable for that item.
#
#    All entries must exist in the module's REWARD_GROUPS catalog — i.e. they
#    must be valid items redeemable at one of the five vendor NPCs.  Any item
#    not found in any catalog will log a warning at the time of the kill and
#    the drop will be skipped for that kill.
#
#    Example (ALL TCG ITEM IDs): TCGVendors.BossDrop.ItemIds = 23705,23713,23720,32566,32588,32542,33219,33223,33225,34499,34492,34493,35226,35223,35227,38233,38301,38050,38577,38578,38576,45047,45037,45063,46779,46780,46778,49287,49343,54218,54212,54069,54455,54452,54068,23709,23714,23716,38310,38312,38314,38313,38309,38311,50301,20371,33079,43599,22114,20651,22780,46802,45180,13582,13583,13584,25535,39286,39656,46767,48527,49646,49662,49663,49665,49693,54847,56806,49362
#
#    Default: (empty — boss drop produces nothing without at least one item)
#
TCGVendors.BossDrop.ItemIds =

###############################################################################
#  TCGVendors.BossDrop.MailParticipants
#
#    Controls whether group/raid participants receive a unique stationery item
#    via in-game mail, and whether the loot-window drop on the corpse is active.
#
#    0 - Disabled  (default)
#        No mail is sent.  A single stationery item appears on the boss corpse
#        via the loot template (claimed by whoever loots it first, or distributed
#        by master looter).  Loot template rows for item 9311 are inserted on
#        startup for all entries in BossDrop.CreatureIds.
#
#    1 - Mail only
#        Every qualifying group/raid member present on the same map receives
#        a stationery item in their mailbox, each containing a unique code.
#        No loot template rows are inserted — the stationery does NOT appear
#        on the boss corpse.  Existing 9311 rows are purged on startup.
#        Solo players (no group) receive mail to themselves.
#
#    2 - Mail AND loot
#        Every qualifying participant receives a mailed stationery with their
#        own unique code, AND a single stationery item appears on the boss
#        corpse as a loot-window drop.  Both paths are active simultaneously.
#
#    Default: 0
#
TCGVendors.BossDrop.MailParticipants = 0
